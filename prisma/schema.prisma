generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  USER
  ADMIN
}

model User {
  userId              Int        @id @default(autoincrement())
  name                String
  email               String     @unique
  password            String
  role                Role       @default(USER)
  salaries            Salary[]
  bonuses             Bonus[]
  discounts           Discount[]
  debts               Debts[]
  monthlyExpenseLimit Float      @default(0)
}

enum SalaryParameter {
  MOTHLY
  FORHOUR
  FORTNIGHTLY
}

model Salary {
  salaryId   Int             @id @default(autoincrement())
  amount     Float
  userId     Int
  datebegin  DateTime
  createdAt  DateTime        @default(now())
  status     Boolean         @default(true)
  parameter  SalaryParameter
  user       User            @relation(fields: [userId], references: [userId])
  dayPayment Int?
}

model Bonus {
  bonusId   Int      @id @default(autoincrement())
  amount    Float
  note      String
  userId    Int
  date      DateTime
  createdAt DateTime @default(now())
  status    Boolean  @default(true)
  user      User     @relation(fields: [userId], references: [userId])
}

model Discount {
  discountId Int      @id @default(autoincrement())
  amount     Float
  note       String
  userId     Int
  date       DateTime
  createdAt  DateTime @default(now())
  status     Boolean  @default(true)
  user       User     @relation(fields: [userId], references: [userId])
}

model Debts {
  debtId            Int           @id @default(autoincrement())
  maxMothlyPayment  Float
  totalInstallments Int
  paidInstallments  Int           @default(0)
  payment           Float
  title             String
  description       String
  startDate         DateTime
  endDate           DateTime
  userId            Int
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  status            Boolean       @default(true)
  user              User          @relation(fields: [userId], references: [userId])
  payments          DebtPayment[]
}

model DebtPayment {
  debtPaymentId Int      @id @default(autoincrement())
  amount        Float
  date          DateTime
  debtId        Int
  debt          Debts    @relation(fields: [debtId], references: [debtId])
}

model Calendar {
  calendarId Int        @id @default(autoincrement())
  name       String
  isPublic   Boolean
  status     Boolean    @default(true)
  schedules  Schedule[]
}

model Schedule {
  scheduleId  Int       @id @default(autoincrement())
  title       String
  description String
  date        DateTime
  startTime   DateTime
  endTime     DateTime
  color       String
  calendarId  Int?
  calendar    Calendar? @relation(fields: [calendarId], references: [calendarId])
  imageId     Int?
  image       Images?   @relation(fields: [imageId], references: [imageId])
}

model Todos {
  todosId  Int     @id @default(autoincrement())
  title    String
  status   Boolean @default(true)
  isPublic Boolean @default(false)
  todos    Todo[]
}

enum TodoStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELED
  DRAFT
  ARCHIVED
}

model Todo {
  todoId           Int         @id @default(autoincrement())
  title            String
  description      String
  status           TodoStatus  @default(PENDING)
  todosId          Int
  todos            Todos       @relation(fields: [todosId], references: [todosId])
  images           TodoImage[]
  isArchived       Boolean     @default(false)
  pinned           Boolean     @default(false)
  completedAt      DateTime?
  hourNotification DateTime?
  importance       Int         @default(0)
}

model TodoImage {
  todoImageId Int    @id @default(autoincrement())
  todoId      Int
  todo        Todo   @relation(fields: [todoId], references: [todoId])
  imageId     Int
  image       Images @relation(fields: [imageId], references: [imageId])
}

model Images {
  imageId   Int         @id @default(autoincrement())
  url       String
  public_id String      @default("Untitled")
  todoImage TodoImage[]
  schedule  Schedule[]
}

model Archives {
  archiveId Int      @id @default(autoincrement())
  url       String
  public_id String
  type      String
  name      String   @default("Untitled")
  createdAt DateTime @default(now())
  folderId  Int?
  folder    Folder?  @relation(fields: [folderId], references: [folderId])
}

model Folder {
  folderId       Int        @id @default(autoincrement())
  name           String
  archives       Archives[]
  isPublic       Boolean    @default(false)
  parentFolderId Int?
  parent         Folder?    @relation("FolderHierarchy", fields: [parentFolderId], references: [folderId])
  folders        Folder[]   @relation("FolderHierarchy")
}
